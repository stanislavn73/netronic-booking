    "reset:seed:tiny": "tsx scripts/reset-seed-tiny.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/cors": "^10.0.0",
    "@pothos/core": "^4.3.0",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.3.0",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.23.0",
    "pg": "^8.13.0",
    "pg-copy-streams": "^6.0.6",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "drizzle-kit": "^0.28.0",
