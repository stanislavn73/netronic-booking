# Web env vars — copy to `.env.local` (gitignored) for local overrides.
# Anything prefixed VITE_ is inlined into the client bundle at build time.

# GraphQL endpoint. In dev the Vite proxy forwards /graphql → :4000, so this
# can be left unset locally. Set it explicitly for production builds:
#   VITE_API_URL=https://my-api.onrender.com/graphql
# VITE_API_URL=/graphql
